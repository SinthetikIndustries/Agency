{
  "_comment": "This is the shape of ~/.agency/config.json — generated by `agency install`. No secrets here.",
  "name": "YOUR_NAME",
  "profile": "basic",
  "repoDir": "/path/to/cloned/agency/repo",
  "gatewayDir": "/path/to/cloned/agency/repo/app/apps/gateway",
  "gateway": {
    "port": 2002,
    "host": "127.0.0.1",
    "logLevel": "info",
    "auth": {
      "jwtSecret": "YOUR_JWT_SECRET_MIN_32_CHARS",
      "jwtExpiryHours": 24
    },
    "rateLimit": {
      "max": 100,
      "timeWindow": "1 minute"
    }
  },
  "modelRouter": {
    "defaultModel": "claude-sonnet-4-6",
    "tiers": {
      "cheap": "claude-haiku-4-5",
      "strong": "claude-sonnet-4-6"
    },
    "providers": {
      "anthropic": { "enabled": true },
      "openai": { "enabled": false },
      "ollama": { "enabled": true, "endpoint": "http://localhost:2005" },
      "ollamaCloud": { "enabled": false, "endpoint": "https://ollama.com" },
      "openrouter": { "enabled": false }
    },
    "fallback": { "cheap": null, "strong": "claude-sonnet-4-6" },
    "embedding": { "provider": "openai", "model": "text-embedding-3-small" }
  },
  "daemons": {
    "orchestrator": { "enabled": true },
    "modelRouter": { "enabled": true },
    "vaultSync": { "enabled": false, "_note": "Deprecated — The Brain (PostgreSQL knowledge graph) replaces file-based vault sync" }
  },
  "orchestrator": {
    "defaultAgent": "main",
    "maxWorkflowSteps": 20,
    "approvalTimeoutSeconds": 300
  },
  "redis": { "url": "redis://localhost:2004" }
}
